# Tracked ssh client config -> ~/.ssh/config
#
# Two ways to hold a key, in preference order. 1Password's SSH agent is the
# intended one: the key never touches the disk. It is a feature of the desktop
# app, not the `op` CLI, so the app must be installed and unlocked -- and it
# currently cannot be installed on ostree systems at all (see
# modules/packages/apps.d/1password.sh). An on-disk key is the fallback for
# machines in that state.

# ssh_config is first-obtained-wins, so this has to precede `Host *` for the
# agent to beat the on-disk key.
#
# The test asks the agent to list keys rather than checking that its socket
# exists. The socket file outlives the app that served it -- quit 1Password and
# ~/.1password/agent.sock is still there, refusing connections -- so existence
# says nothing about whether anything is listening, and `test -S` selects a
# dead agent as readily as a live one.
#
# ssh-add exits 2 when it cannot reach the agent and 1 when it reached one that
# holds no keys, so only 2 means "not usable". The 1 case is a locked
# 1Password, which is still the right identity to use: it prompts and unlocks.
# timeout covers an agent that accepts the connection and then does not answer,
# and its 124 falls through to the on-disk key like any other failure.
Match exec "SSH_AUTH_SOCK=%d/.1password/agent.sock timeout 2 ssh-add -l >/dev/null 2>&1 || [ $? -eq 1 ]"
	IdentityAgent ~/.1password/agent.sock

Host *
	# Only consulted when the agent above didn't answer. ssh would find this
	# path on its own, but naming it keeps the fallback visible to a reader.
	# No IdentitiesOnly: it limits ssh to keys with a matching file on disk,
	# and the 1Password agent's keys have none, so it would break the path
	# above rather than tighten it.
	IdentityFile ~/.ssh/id_rsa

	# Drop dead connections rather than hanging until TCP gives up.
	ServerAliveInterval 60
	ServerAliveCountMax 3
