# ShellCheck configuration for this repo.

# SC2034 -- "appears unused". Nearly every file here sets variables that another
# file consumes: apps.d entries declare APP_NAME and APP_GROUP for the packages
# module to read, installers set DRY_RUN for lib/common.sh's `dry`, and doctor.sh
# sets MODULE for the checks.sh it sources. ShellCheck cannot see across that
# boundary, so the check is a false positive by construction here rather than
# occasionally.
disable=SC2034
